# Environment configuration for Docker container with Gazebo

# Enable Gazebo simulation mode
USE_GAZEBO=true
GAZEBO_HOST=192.168.1.28
# MAVLink connection to ArduPilot SITL
MAVLINK_HOST=host.docker.internal
MAVLINK_PORT=5763

# Sky Anchor Configuration
DRONE_CAMERA_TYPE=GAZEBO
DRONE_CAMERA_INDEX=0
DRONE_CAPTURE_WIDTH=640
DRONE_CAPTURE_HEIGHT=480
DRONE_CAPTURE_FPS=30

# Gazebo camera topic - Update this based on your Gazebo world
# Common topics:
# - /world/default/model/iris_with_gimbal/model/gimbal/link/pitch_link/sensor/camera/image
# - /gazebo/default/iris_demo/iris_demo/gimbal_small_2d/tilt_link/camera/image
# - /gazebo/default/iris_demo/iris_demo/gimbal_cam_link/gimbal_cam/image
GAZEBO_CAMERA_TOPIC=/gazebo/default/down_cam/cam_link/nadir_camera/image
# Drift detection thresholds
DRONE_SHIFT_THRESHOLD=1
DRONE_ANGLE_THRESHOLD=1

# ORB features
DRONE_ORB_NFEATURES=500
MAX_FEATURE_FAILS=5

# Image processing
NORMALIZE_TYPE=0

# Performance
DRONE_SLEEP_TIME=0.01
ENABLE_CUDA=False
DRONE_DEBUG=False

# Flight controller (MAVLink to ArduPilot SITL)
DRONE_FC_TYPE=MAVLINK
# Use TCP connection to host's ArduPilot SITL
DRONE_FC_DEVICE=tcp:host.docker.internal:5763
DRONE_FC_BAUDRATE=57600

# Logging
SKY_ANCHOR_LOG_PATH=/drone_project/logs/sky_anchor.log
DRONE_LOG_LEVEL=INFO