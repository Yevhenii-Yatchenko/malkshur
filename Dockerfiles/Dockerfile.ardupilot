FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies
RUN apt-get update && apt-get install -y \
    git \
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    build-essential \
    ccache \
    g++ \
    gawk \
    libpython3-dev \
    # For MAVProxy GUI (map, console)
    python3-tk \
    libgirepository1.0-dev \
    gir1.2-gtk-3.0 \
    # X11 for GUI
    x11-apps \
    && rm -rf /var/lib/apt/lists/*

# Clone ArduPilot
WORKDIR /ardupilot
RUN git clone --recurse-submodules --depth 1 https://github.com/ArduPilot/ardupilot.git .

# Inject custom locations (OSRF0=1,0,0.2,0)
COPY docker_data/ardupilot_sitl/locations.txt /ardupilot/Tools/autotest/locations.txt

# Create venv and install Python dependencies
RUN python3 -m venv /opt/ardupilot-venv && \
    /opt/ardupilot-venv/bin/pip install --upgrade pip && \
    /opt/ardupilot-venv/bin/pip install \
        empy==3.3.4 \
        pexpect \
        future \
        pymavlink \
        MAVProxy \
        dronecan \
        packaging \
        setuptools \
        wheel \
        pyserial

# Set venv as default
ENV PATH="/opt/ardupilot-venv/bin:$PATH"
ENV VIRTUAL_ENV="/opt/ardupilot-venv"

# Build ArduCopter SITL
RUN ./waf configure --board sitl && \
    ./waf build --target bin/arducopter
